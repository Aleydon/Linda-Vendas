{
  "name": "linda-vendas",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:apk": "eas build -p android --profile preview",
    "build:android:local:apk": "NODE_ENV=production eas build -p android --profile preview --local",
    "build:android:aab": "eas build -p android --profile production",
    "build:ios": "eas build -p ios --profile production",
    "update:prod": "eas update --channel production",
    "update:apk": "eas update --channel preview",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "eslint . --fix --ext .tsx,.ts,.jsx,.js",
    "prepare": "husky",
    "commit": "eslint . --fix --ext .tsx,.ts && prettier --write .  && git add . && cz"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/server": "^0.5.3",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.105.3",
    "buffer": "^6.0.3",
    "expo": "53.0.27",
    "expo-auth-session": "~6.2.1",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "nativewind": "4.1.23",
    "papaparse": "^5.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
